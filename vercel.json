{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/generate.js": {
      "memory": 1024,
      "maxDuration": 180,
      "includeFiles": "fonts/**"
    },
    "api/search.js": {
      "maxDuration": 30
    },
    "api/mockups.js": {
      "maxDuration": 30
    },
    "api/prowl.js": {
      "maxDuration": 60
    },
    "api/pounce.js": {
      "maxDuration": 60
    },
    "api/site.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/v/:slug", "destination": "/api/view?slug=:slug" },
    { "source": "/i/:slug", "destination": "/api/img?slug=:slug" },
    { "source": "/s/:slug", "destination": "/api/site?slug=:slug" }
  ],
  "headers": [
    {
      "source": "/(index.html)?",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/:file(app.js|styles.css|data.js)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}

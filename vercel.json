{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/generate.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "fonts/**"
    },
    "api/search.js": {
      "maxDuration": 30
    },
    "api/mockups.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/v/:slug", "destination": "/api/view?slug=:slug" },
    { "source": "/i/:slug", "destination": "/api/img?slug=:slug" }
  ]
}

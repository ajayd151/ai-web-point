# These are set in Vercel → Project → Settings → Environment Variables.
# You do NOT put real values in this file; it's just a reference.

# Required: your OpenAI key (powers the AI image). Create at platform.openai.com
OPENAI_API_KEY=

# Auto-added by Vercel when you create a Blob store (Storage tab). Do not set by hand.
BLOB_READ_WRITE_TOKEN=

# Optional: where the "Request a demo" button links (your booking page or email).
# e.g. https://aiwebpoint.com/book  or  mailto:hello@aiwebpoint.com
DEMO_URL=

# Optional: gpt-image-1 quality (low | medium | high). Higher = better but pricier.
OPENAI_IMAGE_QUALITY=medium
